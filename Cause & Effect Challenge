<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Cause & Effect Challenge | Teacher Review Quiz</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: linear-gradient(145deg, #e0eaf4 0%, #cfdef3 100%);
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            padding: 30px 20px;
            color: #1a2c3e;
        }

        /* main container */
        .dashboard {
            max-width: 1300px;
            margin: 0 auto;
        }

        /* header & teacher panel */
        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .header h1 {
            font-size: 2.2rem;
            background: #1e3c5c;
            display: inline-block;
            padding: 12px 28px;
            border-radius: 60px;
            color: white;
            box-shadow: 0 8px 18px rgba(0,0,0,0.1);
            letter-spacing: -0.3px;
        }

        .teacher-zone {
            background: #2c3e2f;
            color: white;
            border-radius: 32px;
            padding: 20px 28px;
            margin-bottom: 30px;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            box-shadow: 0 6px 14px rgba(0,0,0,0.15);
        }

        .teacher-zone h3 {
            font-weight: 500;
            background: #ffcd7e;
            display: inline-block;
            padding: 5px 15px;
            border-radius: 40px;
            color: #2c3e2f;
            font-size: 1rem;
        }

        .teacher-buttons {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .btn {
            border: none;
            background: white;
            padding: 10px 20px;
            border-radius: 40px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s ease;
            font-size: 0.9rem;
            font-family: inherit;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .btn-primary {
            background: #ffcd7e;
            color: #2c3e2f;
        }

        .btn-primary:hover {
            background: #ffbc4a;
            transform: scale(0.97);
        }

        .btn-danger {
            background: #f4acb7;
            color: #7a2e3a;
        }

        .btn-danger:hover {
            background: #ec8b9a;
        }

        .btn-outline {
            background: transparent;
            border: 2px solid white;
            color: white;
        }

        .btn-outline:hover {
            background: white;
            color: #2c3e2f;
        }

        .stats {
            background: #f8f9fc;
            border-radius: 28px;
            padding: 10px 20px;
            font-weight: bold;
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }

        /* quiz grid */
        .quiz-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(550px, 1fr));
            gap: 24px;
            margin-bottom: 40px;
        }

        .question-card {
            background: white;
            border-radius: 36px;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            transition: all 0.2s;
            border: 1px solid rgba(0,0,0,0.05);
        }

        .question-header {
            background: #1e3c5c;
            padding: 16px 24px;
            color: white;
            font-weight: bold;
            font-size: 1.1rem;
            letter-spacing: -0.2px;
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
        }

        .q-num {
            background: #ffcd7e;
            color: #1e3c5c;
            padding: 4px 12px;
            border-radius: 40px;
            font-size: 0.8rem;
        }

        .question-text {
            padding: 20px 24px 10px 24px;
            font-size: 1rem;
            line-height: 1.45;
            background: #ffffff;
            border-bottom: 1px solid #e9edf2;
        }

        .question-text strong {
            color: #1e5a7a;
        }

        .options {
            padding: 16px 24px 24px 24px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .option-row {
            display: flex;
            align-items: center;
            gap: 12px;
            background: #f9fafc;
            padding: 10px 15px;
            border-radius: 60px;
            border: 1px solid #e2e8f0;
            transition: 0.1s;
        }

        .option-row input {
            width: 20px;
            height: 20px;
            accent-color: #2c7a4d;
            cursor: pointer;
        }

        .option-row label {
            font-size: 0.95rem;
            font-weight: 500;
            color: #1f2f3e;
            cursor: pointer;
            flex: 1;
        }

        .feedback-area {
            padding: 0 24px 20px 24px;
            font-size: 0.8rem;
            min-height: 40px;
        }

        .submitted-badge {
            background: #d1fae5;
            color: #0b5e2e;
            border-radius: 24px;
            padding: 6px 12px;
            font-size: 0.75rem;
            font-weight: bold;
            display: inline-block;
        }

        hr {
            margin: 0 20px;
            border-color: #edf2f7;
        }

        .submit-all {
            text-align: center;
            margin: 20px 0 30px;
        }

        .btn-submit-master {
            background: #1e5a7a;
            color: white;
            font-size: 1.2rem;
            padding: 14px 38px;
            border-radius: 60px;
            border: none;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 5px 12px rgba(0,0,0,0.2);
            transition: 0.1s linear;
        }

        .btn-submit-master:hover {
            background: #13445c;
            transform: scale(0.98);
        }

        .footer-note {
            text-align: center;
            margin-top: 20px;
            font-size: 0.8rem;
            color: #3e5a6b;
        }

        @media (max-width: 650px) {
            .quiz-grid {
                grid-template-columns: 1fr;
            }
            .teacher-zone {
                flex-direction: column;
                align-items: stretch;
            }
        }
    </style>
</head>
<body>
<div class="dashboard">
    <div class="header">
        <h1>🌍 CAUSE ↔ EFFECT CHALLENGE</h1>
        <p style="margin-top: 10px;">Choose the correct word/phrase to complete each sentence. Submit your answers — teacher reviews them later.</p>
    </div>

    <!-- Teacher control panel -->
    <div class="teacher-zone">
        <div>
            <h3>👩‍🏫 TEACHER REVIEW MODE</h3>
            <div class="stats" id="submissionStats" style="margin-top: 8px; background:#3a5a3a; color:white;">
                📊 No submissions yet
            </div>
        </div>
        <div class="teacher-buttons">
            <button class="btn btn-primary" id="viewSubmissionsBtn">📋 VIEW ALL SUBMISSIONS (JSON)</button>
            <button class="btn btn-outline" id="downloadReportBtn">📥 DOWNLOAD REPORT (.CSV)</button>
            <button class="btn btn-danger" id="clearSubmissionsBtn">🗑️ CLEAR ALL SUBMISSIONS</button>
        </div>
    </div>

    <!-- QUIZ container -->
    <div id="quizContainer" class="quiz-grid"></div>
    
    <div class="submit-all">
        <button class="btn-submit-master" id="submitAllBtn">✅ SUBMIT MY ANSWERS TO TEACHER</button>
    </div>
    <div class="footer-note">
        💡 After you submit, the teacher can review your answers using the panel above. You can change answers and re-submit anytime — only the latest submission per student is stored (using your name).
    </div>
</div>

<script>
    // ---------- QUIZ DATA (based on the worksheet with accurate correct answers) ----------
    // Each question: id, text, options array, correctAnswers (array of strings)
    // According to the provided task, multiple correct answers per gap exist.
    const questionsData = [
        { id: 1, text: "Many experts believe that CO₂ emissions from industry and vehicles have (...) global warming.", 
          options: ["caused", "stemmed from", "brought about", "led to", "been caused by"],
          correct: ["caused", "brought about", "led to"] },
        { id: 2, text: "Sea levels have begun to rise (...) to global warming.", 
          options: ["leading", "owing", "due", "giving rise", "thanks"],
          correct: ["owing", "due"] },
        { id: 3, text: "The destruction of forest habitats has (...) many animal species to die out.", 
          options: ["led", "resulted in", "caused", "brought about", "given rise to"],
          correct: ["led", "resulted in", "caused", "brought about", "given rise to"] },  // all except 'resulted in' works? but 'led' works: 'led many species to die out'. Actually 'resulted in' requires noun phrase: it's acceptable. Keep all but worksheet note: "resulted in" is correct with gerund.
          // But we keep all as correct according to academic usage. From worksheet: "led, resulted in, caused, brought about, given rise to" are valid.
        { id: 4, text: "Marine life in the world's seas is being devastated (...) overfishing.", 
          options: ["due to", "as a result of", "leading to", "giving rise to", "because of"],
          correct: ["due to", "as a result of", "because of"] },  // "leading to" would shift direction
        { id: 5, text: "In many parts of the world, once fertile land is turning into semi-desert (...) intensive farming methods.", 
          options: ["owing to", "leading to", "since", "resulting in", "on account of"],
          correct: ["owing to", "on account of"] },  // "since" needs full clause, not noun phrase.
        { id: 6, text: "Accidents at sea involving large oil tankers have often (...) environmental damage on a huge scale.", 
          options: ["been due to", "been caused by", "given rise to", "led to", "stemmed from"],
          correct: ["given rise to", "led to"] },
        { id: 7, text: "The difficulty meteorologists have in making predictions about climate change (...) the complexity of global weather systems.", 
          options: ["results in", "is due to", "stems from", "results from", "brings about"],
          correct: ["is due to", "stems from", "results from"] },  // effect -> cause phrases
        { id: 8, text: "Public awareness of environmental issues is far greater than it used to be (...) energetic campaigning by environmentalists.", 
          options: ["on account of", "thanks to", "as a consequence of", "resulting in", "because"],
          correct: ["on account of", "thanks to", "as a consequence of"] }, // because needs full clause
        { id: 9, text: "Zoos can sometimes help prevent certain species from becoming extinct (...) they can breed the animals in captivity.", 
          options: ["owing to", "because", "due to", "on account of", "since"],
          correct: ["because", "since"] },  // need full clause (they can breed)
        { id: 10, text: "Poor air quality in urban areas is known to have (...) an increase in breathing disorders such as asthma.", 
          options: ["stemmed from", "given rise to", "resulted in", "brought about", "resulted from"],
          correct: ["given rise to", "resulted in", "brought about"] }
    ];

    // Storage key for teacher submissions (array of student answers)
    let submissions = []; // each entry: { studentName: string, timestamp: string, answers: { q1: selectedOption, ... }, resultsSummary }

    // Load from localStorage if any
    function loadSubmissionsFromStorage() {
        const stored = localStorage.getItem("teacher_cause_effect_submissions");
        if(stored) {
            try {
                submissions = JSON.parse(stored);
            } catch(e) { submissions = []; }
        } else {
            submissions = [];
        }
        updateTeacherStats();
    }

    function saveSubmissionsToStorage() {
        localStorage.setItem("teacher_cause_effect_submissions", JSON.stringify(submissions));
        updateTeacherStats();
    }

    function updateTeacherStats() {
        const statsDiv = document.getElementById("submissionStats");
        if(statsDiv) {
            const count = submissions.length;
            if(count === 0) statsDiv.innerHTML = "📊 No submissions yet. Students can submit answers below.";
            else statsDiv.innerHTML = `📋 ${count} submission(s) received. Use "VIEW ALL" to inspect answers.`;
        }
    }

    // helper: compute correctness for a given set of answers (obj mapping qId -> selected value string)
    function computeResults(answersMap) {
        let score = 0;
        let details = [];
        questionsData.forEach(q => {
            const userAnswer = answersMap[q.id] || "";
            const isCorrect = q.correct.includes(userAnswer);
            if(isCorrect) score++;
            details.push({
                id: q.id,
                userAnswer: userAnswer || "(no answer)",
                correctOptions: q.correct,
                isCorrect: isCorrect
            });
        });
        return { score, total: questionsData.length, details };
    }

    // render dynamic quiz with radio buttons (each question selects one option)
    let currentStudentAnswers = {};  // store current selections in memory (id -> selected option)

    function renderQuiz() {
        const container = document.getElementById("quizContainer");
        if(!container) return;
        container.innerHTML = "";
        questionsData.forEach(q => {
            const card = document.createElement("div");
            card.className = "question-card";
            card.dataset.qid = q.id;
            
            const headerDiv = document.createElement("div");
            headerDiv.className = "question-header";
            headerDiv.innerHTML = `<span>❓ Question ${q.id}</span><span class="q-num">${q.correct.length} valid option(s)</span>`;
            
            const textDiv = document.createElement("div");
            textDiv.className = "question-text";
            textDiv.innerHTML = `<strong>${q.text}</strong>`;
            
            const optionsDiv = document.createElement("div");
            optionsDiv.className = "options";
            
            // create radio group
            q.options.forEach(opt => {
                const row = document.createElement("div");
                row.className = "option-row";
                const radioId = `q${q.id}_opt_${opt.replace(/\s/g, '')}`;
                const isChecked = (currentStudentAnswers[q.id] === opt);
                const radio = document.createElement("input");
                radio.type = "radio";
                radio.name = `question_${q.id}`;
                radio.value = opt;
                radio.id = radioId;
                if(isChecked) radio.checked = true;
                radio.addEventListener("change", (e) => {
                    if(e.target.checked) {
                        currentStudentAnswers[q.id] = opt;
                        // update local feedback row optional
                        updateQuestionFeedback(q.id, opt);
                    }
                });
                const label = document.createElement("label");
                label.htmlFor = radioId;
                label.textContent = opt;
                row.appendChild(radio);
                row.appendChild(label);
                optionsDiv.appendChild(row);
            });
            
            const feedbackDiv = document.createElement("div");
            feedbackDiv.className = "feedback-area";
            feedbackDiv.id = `fb_q${q.id}`;
            
            card.appendChild(headerDiv);
            card.appendChild(textDiv);
            card.appendChild(optionsDiv);
            card.appendChild(feedbackDiv);
            container.appendChild(card);
            
            // if there is already a selection, show feedback
            if(currentStudentAnswers[q.id]) {
                updateQuestionFeedback(q.id, currentStudentAnswers[q.id]);
            }
        });
    }
    
    function updateQuestionFeedback(qid, selectedVal) {
        const q = questionsData.find(qq => qq.id === qid);
        if(!q) return;
        const feedbackDiv = document.getElementById(`fb_q${qid}`);
        if(!feedbackDiv) return;
        const isCorrect = q.correct.includes(selectedVal);
        if(isCorrect) {
            feedbackDiv.innerHTML = `<span style="background:#e6f7e6; padding:4px 12px; border-radius:20px; color:#2b6e3c;">✓ Good choice! “${selectedVal}” is correct for this gap.</span>`;
        } else {
            let hint = `⚠️ “${selectedVal}” is not the best fit. Correct options: ${q.correct.join(", ")}. Check cause/effect direction.`;
            feedbackDiv.innerHTML = `<span style="background:#ffe6e5; padding:4px 12px; border-radius:20px; color:#b13e3e;">${hint}</span>`;
        }
    }
    
    // SUBMIT FUNCTION (student submits their answers to teacher storage)
    function submitToTeacher() {
        // check if any question unanswered? we allow partial but give warning
        let missing = [];
        for(let i=1; i<=10; i++) {
            if(!currentStudentAnswers[i]) missing.push(i);
        }
        let studentNameRaw = prompt("📝 Enter your name (or student ID) so your teacher can identify your submission:", "Student_" + Math.floor(Math.random()*1000));
        if(!studentNameRaw || studentNameRaw.trim() === "") {
            alert("Name is required to submit answers.");
            return;
        }
        const studentName = studentNameRaw.trim();
        if(missing.length > 0) {
            if(!confirm(`⚠️ You haven't answered question(s): ${missing.join(", ")}. Do you still want to submit? Teacher will see incomplete answers.`)) {
                return;
            }
        }
        
        // Build answers map
        const finalAnswers = {};
        for(let i=1; i<=10; i++) {
            finalAnswers[i] = currentStudentAnswers[i] || "";
        }
        const result = computeResults(finalAnswers);
        
        // Create submission object
        const submission = {
            studentName: studentName,
            timestamp: new Date().toLocaleString(),
            answers: { ...finalAnswers },
            score: result.score,
            total: result.total,
            details: result.details
        };
        
        // Check if student already submitted? We will replace previous submission by same name (latest)
        const existingIndex = submissions.findIndex(s => s.studentName === studentName);
        if(existingIndex !== -1) {
            submissions[existingIndex] = submission;
            alert(`✅ Submission updated for ${studentName}. Your previous answers replaced.`);
        } else {
            submissions.push(submission);
            alert(`🎉 Submission saved for ${studentName}! Teacher can now review your answers.`);
        }
        saveSubmissionsToStorage();
        
        // optional: refresh teacher stats display
        updateTeacherStats();
    }
    
    // Teacher: view all submissions as formatted JSON modal
    function viewSubmissions() {
        if(submissions.length === 0) {
            alert("No student submissions yet. Ask students to submit their answers using the form above.");
            return;
        }
        let reportText = "===== STUDENT CAUSE-EFFECT SUBMISSIONS =====\n\n";
        submissions.forEach((sub, idx) => {
            reportText += `[${idx+1}] Student: ${sub.studentName} | Submitted: ${sub.timestamp} | Score: ${sub.score}/${sub.total}\n`;
            reportText += `Answers:\n`;
            for(let qid=1; qid<=10; qid++) {
                const ans = sub.answers[qid] || "—";
                const qData = questionsData.find(q => q.id === qid);
                const correctStatus = qData.correct.includes(ans) ? "✓" : "✗";
                reportText += `   Q${qid}: ${ans} ${correctStatus} (expected: ${qData.correct.join("/")})\n`;
            }
            reportText += `----------------------------------------\n`;
        });
        // display in a textarea popup
        const modalDiv = document.createElement("div");
        modalDiv.style.position = "fixed";
        modalDiv.style.top = "0";
        modalDiv.style.left = "0";
        modalDiv.style.width = "100%";
        modalDiv.style.height = "100%";
        modalDiv.style.backgroundColor = "rgba(0,0,0,0.75)";
        modalDiv.style.display = "flex";
        modalDiv.style.alignItems = "center";
        modalDiv.style.justifyContent = "center";
        modalDiv.style.zIndex = "1000";
        const content = document.createElement("div");
        content.style.backgroundColor = "white";
        content.style.width = "90%";
        content.style.maxWidth = "800px";
        content.style.maxHeight = "80%";
        content.style.borderRadius = "32px";
        content.style.padding = "20px";
        content.style.overflow = "auto";
        content.style.fontFamily = "monospace";
        content.style.whiteSpace = "pre-wrap";
        content.innerHTML = `<h3 style="margin-bottom:10px;">📋 All student submissions</h3><pre style="font-size:12px; background:#f4f7fc; padding:12px; border-radius:20px;">${reportText}</pre><button id="closeModalBtn" style="margin-top:15px; padding:8px 20px; border-radius:40px; border:none; background:#1e3c5c; color:white; cursor:pointer;">Close</button>`;
        modalDiv.appendChild(content);
        document.body.appendChild(modalDiv);
        document.getElementById("closeModalBtn").addEventListener("click", () => {
            modalDiv.remove();
        });
    }
    
    // download CSV report for teacher (excel friendly)
    function downloadCSV() {
        if(submissions.length === 0) {
            alert("No submissions available to export.");
            return;
        }
        let csvRows = [];
        // headers
        let headers = ["StudentName", "Timestamp", "Score", "Total"];
        for(let i=1; i<=10; i++) {
            headers.push(`Q${i}_Answer`);
            headers.push(`Q${i}_Correct`);
        }
        csvRows.push(headers.join(","));
        
        submissions.forEach(sub => {
            let row = [
                `"${sub.studentName}"`,
                `"${sub.timestamp}"`,
                sub.score,
                sub.total
            ];
            for(let qid=1; qid<=10; qid++) {
                const answer = sub.answers[qid] || "";
                const qData = questionsData.find(q => q.id === qid);
                const isCorr = qData.correct.includes(answer);
                row.push(`"${answer.replace(/"/g, '""')}"`);
                row.push(isCorr ? "YES" : "NO");
            }
            csvRows.push(row.join(","));
        });
        const blob = new Blob(["\uFEFF" + csvRows.join("\n")], { type: "text/csv;charset=utf-8;" });
        const link = document.createElement("a");
        const url = URL.createObjectURL(blob);
        link.href = url;
        link.setAttribute("download", "cause_effect_submissions.csv");
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);
        alert("CSV report downloaded! Open with Excel or Google Sheets.");
    }
    
    function clearAllSubmissions() {
        if(confirm("⚠️ DANGER: This will permanently delete ALL student submissions. Are you ABSOLUTELY sure? (Teacher only)")) {
            submissions = [];
            saveSubmissionsToStorage();
            updateTeacherStats();
            alert("All submissions have been cleared.");
        }
    }
    
    // Event listeners and initialization
    document.addEventListener("DOMContentLoaded", () => {
        loadSubmissionsFromStorage();
        // initialize currentStudentAnswers from any previous? not needed; each session fresh.
        // but we can optionally try to populate from localStorage drafts? but teacher only wants fresh quiz per student. we keep empty.
        currentStudentAnswers = {};
        renderQuiz();
        
        // Buttons events
        const submitBtn = document.getElementById("submitAllBtn");
        if(submitBtn) submitBtn.addEventListener("click", submitToTeacher);
        
        const viewBtn = document.getElementById("viewSubmissionsBtn");
        if(viewBtn) viewBtn.addEventListener("click", viewSubmissions);
        
        const downloadBtn = document.getElementById("downloadReportBtn");
        if(downloadBtn) downloadBtn.addEventListener("click", downloadCSV);
        
        const clearBtn = document.getElementById("clearSubmissionsBtn");
        if(clearBtn) clearBtn.addEventListener("click", clearAllSubmissions);
        
        // small reminder: on window before unload warn if answers unsaved? not needed.
    });
</script>
</body>
</html>
